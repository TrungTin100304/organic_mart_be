# Database
SPRING_APPLICATION_NAME=organic-mart-be
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/organicmart
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true
SERVER_PORT=8080
SPRING_FLYWAY_ENABLED=false
SPRING_FLYWAY_BASELINE_ON_MIGRATE=false
SPRING_FLYWAY_VALIDATE_ON_MIGRATE=true

# JWT
JWT_SECRET=your_jwt_secret_here_min_32_chars_long
JWT_ACCESS_TOKEN_EXPIRATION=86400000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# Mail
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_app_password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# Cloudinary (upload images)
# Rotate these if they have ever been committed to a public repo.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# VietQR / SePay Configuration
# Prefix: vietqr. (mapped to VietQrProperties)
VIETQR_BANK_CODE=TPB
VIETQR_BANK_ID=970423
VIETQR_ACCOUNT_NO=00003981468
VIETQR_ACCOUNT_NAME=
VIETQR_TEMPLATE=compact2

# SePay Configuration
# Prefix: sepay. (mapped to SepayWebhookProperties)
SEPAY_ENABLED=false
# ── KEYS ──────────────────────────────────────────────────────────────────
# SEPAY_API_TOKEN:  outbound SePay API calls (Authorization: Bearer ...)
#                    ← keep this on the SERVER SIDE only, never expose to frontend
# SEPAY_WEBHOOK_API_KEY: inbound webhook auth (Authorization: Apikey ...)
#                    ← configure this in SePay dashboard webhook settings
# ── NOTE ──────────────────────────────────────────────────────────────────
# Generate fresh keys for each environment (dev/staging/production).
# Any key that has appeared in a chat/transcript must be considered
# compromised — do NOT use it in production. Request new keys.
SEPAY_API_TOKEN=
SEPAY_WEBHOOK_API_KEY=
SEPAY_BANK_ACCOUNT=00003981468
SEPAY_BANK_CODE=TPB
SEPAY_ACCOUNT_NAME=
# Webhook URL — configure this in SePay dashboard (not used for request validation)
SEPAY_WEBHOOK_URL=https://organic-mart-be-1.onrender.com/api/sepay/webhook
# ── DASHBOARD SETUP ────────────────────────────────────────────────────────
# In SePay Dashboard → Webhooks:
#   URL:               https://organic-mart-be-1.onrender.com/api/sepay/webhook
#   Content-Type:      application/json
#   Transaction type:  In only
#   Bank account:      00003981468 (TPB)
#   Payment code:      OM (prefix filter — set in SePay dashboard)
#   Authentication:    API Key
#   API Key value:     <your SEPAY_WEBHOOK_API_KEY value>
#   Retry non-2xx:    enabled
# ── OUTBOUND SEPAY API ─────────────────────────────────────────────────────
# SEPAY_API_TOKEN is used for outbound API calls (not webhook).
# Example: GET https://api.sepay.vn/transactions with
#   Authorization: Bearer <SEPAY_API_TOKEN>
#   X-API-Key: <SEPAY_WEBHOOK_API_KEY>

# ── Internal Delivery Configuration ──────────────────────────────────────────────
# Prefix: internal-delivery. (mapped to InternalDeliveryProperties)
DELIVERY_STANDARD_FEE=0
DELIVERY_EXPRESS_FEE=20000
DELIVERY_SCHEDULED_FEE=0
DELIVERY_EXPRESS_MINUTES=30
DELIVERY_STANDARD_MINUTES=60
SHIPPING_DEMO_ENABLED=false

# ── Gemini AI Configuration ────────────────────────────────────────────────────
# Prefix: gemini. (mapped to GeminiProperties)
# API key is kept server-side only — NEVER expose to frontend.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=60

# ── Meal Plan Configuration ────────────────────────────────────────────────────
MEAL_PLAN_MAX_DAYS=7
MEAL_PLAN_MAX_MEALS=4
MEAL_PLAN_MAX_PER_HOUR=5
